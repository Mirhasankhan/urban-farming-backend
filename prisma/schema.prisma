datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id @default(uuid(7)) @db.Uuid
  fullName         String
  email            String            @unique
  password         String
  role             UserRole
  status           UserStatus        @default(Pending)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  vendorProfile    VendorProfile?
  communityPost    CommunityPost[]
  comment          Comment[]
  replies          Reply[]
  rentApplications RentApplication[]
  rents            Rent[]
  orders           Order[]

  @@map("users")
}

model PendingUser {
  id        String   @id @default(uuid(7)) @db.Uuid
  fullName  String
  email     String   @unique
  password  String
  role      UserRole
  otpCode   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("pendingUsers")
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  otpCode   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("otps")
}

model VendorProfile {
  id                  String               @id @default(uuid()) @db.Uuid
  userId              String               @unique @db.Uuid
  farmName            String
  certificationStatus CertificationStatus  @default(NotCertified)
  farmLocation        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sustainabilityCert  SustainabilityCert[]
  produces            Produce[]
  rentalSpaces        RentalSpace[]

  @@map("vendorProfiles")
}

model SustainabilityCert {
  id                String        @id @default(uuid()) @db.Uuid
  vendorId          String        @db.Uuid
  certifyingAgency  String
  certificationDate String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  vendor            VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("SustainabilityCerts")
}

model Produce {
  id                  String              @id @default(uuid()) @db.Uuid
  vendorId            String              @db.Uuid
  name                String
  description         String
  price               Float
  category            ProductCategory
  certificationStatus CertificationStatus @default(NotCertified)
  availableQuantity   Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  vendor              VendorProfile       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders              Order[]

  @@unique([vendorId, name])
  @@map("produces")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  produceId       String      @db.Uuid
  customerId      String      @db.Uuid
  quantity        Int
  subtotal        Float
  status          OrderStatus
  cancelledReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  produce         Produce     @relation(fields: [produceId], references: [id], onDelete: Cascade)
  customer        User        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model RentalSpace {
  id               String            @id @default(uuid()) @db.Uuid
  vendorId         String            @db.Uuid
  location         String
  price            Float
  size             String
  availability     Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  vendor           VendorProfile     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  rentApplications RentApplication[]
  rents            Rent[]

  @@map("rentalSpaces")
}

model RentApplication {
  id        String      @id @default(uuid()) @db.Uuid
  spaceId   String      @db.Uuid
  userId    String      @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  space     RentalSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rentApplications")
}

model Rent {
  id        String      @id @default(uuid()) @db.Uuid
  spaceId   String      @db.Uuid
  userId    String      @db.Uuid
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  space     RentalSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plants    Plant[]

  @@map("rents")
}

model Plant {
  id        String         @id @default(uuid()) @db.Uuid
  rentId    String         @db.Uuid
  plantName String
  quantity  Int
  condition PlantCondition @default(SEEDED)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  rent      Rent           @relation(fields: [rentId], references: [id], onDelete: Cascade)

  @@map("plants")
}

model CommunityPost {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  postContent String
  likes       String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment     Comment[]

  @@map("communityPosts")
}

model Comment {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  postId    String        @db.Uuid
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  replies   Reply[]

  @@map("comments")
}

model Reply {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  commentId String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("replies")
}

enum UserStatus {
  Pending
  Active
  Blocked
}

enum OrderStatus {
  Pending
  Active
  Cancelled
  Completed
  Shipped
}

enum CertificationStatus {
  Certified
  NotCertified
}

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum PlantCondition {
  SEEDED
  GROWING
  GOOD
  FAIR
  POOR
  DAMAGED
  DEAD
}

enum ProductCategory {
  VEGETABLE
  FRUIT
  GRAIN
  DAIRY
  SEED
  TOOL
  FERTILIZER
  HERB
}
