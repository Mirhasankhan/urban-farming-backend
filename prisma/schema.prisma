datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid(7)) @db.Uuid
  fullName      String
  email         String         @unique
  password      String
  role          UserRole
  status        UserStatus     @default(Pending)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  vendorProfile VendorProfile?

  @@map("users")
}

model PendingUser {
  id        String   @id @default(uuid(7)) @db.Uuid
  fullName  String
  email     String   @unique
  password  String
  role      UserRole
  otpCode   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("pendingUsers")
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  otpCode   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("otps")
}

model VendorProfile {
  id                  String               @id @default(uuid()) @db.Uuid
  userId              String               @unique @db.Uuid
  farmName            String
  certificationStatus CertificationStatus  @default(NotCertified)
  farmLocation        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sustainabilityCert  SustainabilityCert[]
  produces            Produce[]

  @@map("vendorProfiles")
}

model SustainabilityCert {
  id                String        @id @default(uuid()) @db.Uuid
  vendorId          String        @db.Uuid
  certifyingAgency  String
  certificationDate String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  vendor            VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("SustainabilityCerts")
}

model Produce {
  id                  String              @id @default(uuid()) @db.Uuid
  vendorId            String              @db.Uuid
  name                String
  description         String
  price               Float
  category            ProductCategory
  certificationStatus CertificationStatus @default(NotCertified)
  availableQuantity   Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  vendor              VendorProfile       @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, name])
  @@map("produces")
}

enum UserStatus {
  Pending
  Active
  Blocked
}

enum CertificationStatus {
  Certified
  NotCertified
}

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum ProductCategory {
  VEGETABLE
  FRUIT
  GRAIN
  DAIRY
  SEED
  TOOL
  FERTILIZER
  HERB
}
